# Database
DATABASE_URL=postgresql+asyncpg://punji:punji_dev@localhost:5432/punji

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=generate-with-python-secrets-token-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM — Primary (required)
GOOGLE_AI_API_KEY=AIza...   # from aistudio.google.com (free)

# LLM — Anthropic (optional)
ANTHROPIC_API_KEY=

# GCP (only needed in production for Vertex AI)
GCP_PROJECT_ID=punji-prod
GCP_REGION=asia-south1

# Google OAuth
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Vector DB (agent memory)
QDRANT_URL=https://....qdrant.io
QDRANT_API_KEY=...

# News
NEWS_API_KEY=...

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# Feature flags
ENABLE_NEWS_MONITORING=true
ENABLE_GOALS=true
ENABLE_BROKER_CONNECT=false

# Financial config (update manually when RBI changes rate)
RBI_REPO_RATE=6.5
